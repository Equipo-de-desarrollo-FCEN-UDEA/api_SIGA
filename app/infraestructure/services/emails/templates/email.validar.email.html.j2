{% extends "email.base.html.j2" %}

{% block title %}Validar correo{% endblock %}

{% block content %}
<div style="margin:0 auto; max-width:600px;">
  <table align="center" role="presentation" style="width:100%; border:0; cellpadding:0; cellspacing:0;">
    <tbody>|
      <!-- Mensaje de bienvenida -->
      <tr>
        <td style="padding:10px 25px; text-align:center;">
          <div style="font-family:Roboto, Helvetica, sans-serif; 
                      font-size:16px; font-weight:300; line-height:24px; 
                      color:#616161;">
               Hola, {{ user.nombre.title() }}
            <p>Bienvenid@ al Sistema Integrado de Gestión Administrativa</p>
          </div>
        </td>
      </tr>

      <!-- Información de activación -->
      <tr>
        <td style="padding:10px 25px; text-align:left;">
          <div style="font-family:Roboto, Helvetica, sans-serif; 
                      font-size:16px; font-weight:300; line-height:24px; 
                      color:#616161;">
            <p>Te informamos que tu usuario fue creado satisfactoriamente. 
               Ahora haces parte del sistema de gestión de solicitudes de la Universidad de Antioquia.</p>
            <p>Generamos el siguiente enlace para que puedas activar tu cuenta:</p>
          </div>
        </td>
      </tr>

      <!-- Botón de activación -->
      <tr>
        <td style="padding:15px 25px; text-align:center;">
          <a href="{{ enlace }}" 
             style="display:inline-block; background:#ffae00; 
                    color:#FFFFFF; font-family:Helvetica; 
                    font-size:14px; font-weight:bold; 
                    line-height:120%; text-decoration:none; 
                    border-radius:10px; padding:10px 25px;">
            Activa tu cuenta aquí
          </a>
        </td>
      </tr>
    </tbody>
  </table>
</div>
{% endblock content %}

{% extends "email.base.html.j2" %}

{% block title %}Recuperar contraseña{% endblock %}

{% block content %}
<div style="margin:0 auto; max-width:600px;">
  <table align="center"
         role="presentation"
        style="width:100%; border:0;
               cellpadding:0; cellspacing:0;">
    <tbody>
      <!-- Saludo -->
      <tr>
        <td style="padding:10px 25px; text-align:center;">
          <div style="font-family:Roboto, Helvetica, sans-serif;
                      font-size:16px; font-weight:300;
                      line-height:24px; color:#616161;">
            Hola, {{ user.nombre }}
          </div>
        </td>
      </tr>

      <!-- Mensaje principal -->
      <tr>
        <td style="padding:10px 25px; text-align:left;">
          <div style="font-family:Roboto, Helvetica, sans-serif;
                      font-size:16px; font-weight:300;
                      line-height:24px; color:#616161;">
            <p>¿Olvidaste tu contraseña?</p>
            <p>Estamos enviando este correo en respuesta a tu
               solicitud de recuperar la contraseña de tu cuenta
               en el Sistema de Gestión Administrativa, UdeA.</p>
            <p>Para cambiar tu contraseña, haz clic en el siguiente enlace:</p>
          </div>
        </td>
      </tr>

      <!-- Botón de recuperación -->
      <tr>
        <td style="padding:15px 25px; text-align:center;">
          <a href="{{ enlace }}"
             style="display:inline-block; background:#21618C;
                    color:#FFFFFF; font-family:Helvetica;
                    font-size:14px; font-weight:bold;
                    line-height:120%; text-decoration:none;
                    border-radius:10px; padding:10px 25px;">
            Recuperar contraseña
          </a>
        </td>
      </tr>

      <!-- Nota adicional -->
      <tr>
        <td style="padding:10px 25px; text-align:left;">
          <div style="font-family:Roboto, Helvetica, sans-serif;
                      font-size:12px; font-weight:300;
                      line-height:18px; color:#616161;">
            <p>Si no reconoces esta solicitud para el cambio de contraseña,
               te sugerimos informar al soporte técnico.</p>
          </div>
        </td>
      </tr>
    </tbody>
  </table>
</div>
{% endblock content %}
